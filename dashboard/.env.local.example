# REQUIRED: Local app
NEXT_PUBLIC_SUPABASE_URL= # Example: https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Supabase publishable/anon key
BACKEND_URL= # Example: https://api.pricevault.de

# REQUIRED FOR PRODUCTION: Observability
NEXT_PUBLIC_SENTRY_DSN= # Sentry Next.js project DSN

# OPTIONAL (default shown)
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SUPPORT_EMAIL=support@pricevault.de
