# REQUIRED: Supabase and migrations
SUPABASE_URL= # Example: https://project-ref.supabase.co
SUPABASE_ANON_KEY= # Supabase publishable/anon key
SUPABASE_SERVICE_KEY= # Supabase service-role key; trusted handlers only
DATABASE_URL= # Example: postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# REQUIRED: Queue and scraping
REDIS_URL= # Example: rediss://default:password@redis-host:6379
BROWSERLESS_TOKEN= # Browserless API token
SCRAPER_CONTACT_URL=https://pricevault.de/bot # Public operator contact for the identifiable crawler user agent

# REQUIRED: Connector secret encryption
CONNECTOR_ENCRYPTION_KEY= # Generate a long random production secret

# REQUIRED FOR PRODUCTION: Transactional email
RESEND_API_KEY= # Example: re_...
RESEND_FROM_EMAIL= # Verified sender address; use onboarding@resend.dev for account-owner tests

# REQUIRED FOR PRODUCTION: Viva Smart Checkout and recurring billing
VIVA_CLIENT_ID= # Smart Checkout OAuth2 client ID
VIVA_CLIENT_SECRET= # Smart Checkout OAuth2 client secret
VIVA_MERCHANT_ID= # Merchant ID used for webhook verification and renewals
VIVA_API_KEY= # Merchant API key used for webhook verification and renewals
VIVA_SOURCE_CODE= # Website/App source code from Viva
VIVA_ENVIRONMENT=demo # Use live only with production credentials

# REQUIRED SAFETY DEFAULTS: production enablement is a separate release decision
ENABLE_AUTOMATIC_REPRICING=false
AUTOMATIC_REPRICING_KILL_SWITCH=true
CAPACITY_WARNING_THRESHOLD=0.70
CAPACITY_CRITICAL_THRESHOLD=0.90
OPS_ALERT_EMAIL=

# REQUIRED FOR PRODUCTION: German VAT invoice issuer details
INVOICE_SELLER_NAME= # Legal company name
INVOICE_SELLER_ADDRESS= # Street, postal code, city, Germany
INVOICE_SELLER_VAT_ID= # German VAT ID (USt-IdNr.)
INVOICE_SELLER_EMAIL= # Billing contact

# REQUIRED FOR PRODUCTION: Observability and public app URL
SENTRY_DSN_BACKEND= # Sentry Python project DSN
APP_URL= # Example: https://app.pricevault.de

# OPTIONAL: LLM fallback when deterministic extraction finds no price
ANTHROPIC_API_KEY= # Example: sk-ant-...

# OPTIONAL: Service endpoints and runtime tuning (defaults shown)
BROWSERLESS_HOST=wss://production-sfo.browserless.io
SENTRY_TRACES_SAMPLE_RATE=0.2
OPS_ALERT_EMAIL=ops@pricevault.de
PORT=8000
ENV=development
LOG_LEVEL=INFO
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=120
SCHEDULER_HEARTBEAT_MAX_AGE_SECONDS=180
SCRAPE_MAX_ATTEMPTS=3
SCRAPE_RETRY_BASE_SECONDS=5
SCRAPE_RETRY_MAX_SECONDS=300
PLATFORM_ADMIN_EMAILS= # Comma-separated support-console admin emails
